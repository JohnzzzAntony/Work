generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Role: "admin" | "employee"
// categorySkills is a JSON-encoded string array of Category ids, e.g. '["cat_1","cat_2"]'
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           String   @default("employee")
  categorySkills String   @default("[]")
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  jobTitle       String?
  phone          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedTasks Task[]      @relation("TaskAssignee")
  createdTasks  Task[]      @relation("TaskCreator")
  activityLogs  ActivityLog[]
  comments      Comment[]
  notifications Notification[]
  followUps     FollowUp[]
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  categories Category[]
}

// type: "branch" | "entity" | "subsidiary" | "store" | "office"
model Branch {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("branch")
  address   String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  tasks  Task[]
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  color        String   @default("#6b7280")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime @default(now())

  tasks Task[]
}

// Priority: "low" | "medium" | "high" | "urgent"
// Status: "new" | "assigned" | "in_progress" | "blocked" | "in_review" | "done" | "closed"
model Task {
  id                 String    @id @default(cuid())
  title              String
  description        String    @default("")
  categoryId         String
  category           Category  @relation(fields: [categoryId], references: [id])
  priority           String    @default("medium")
  status             String    @default("new")
  assigneeId         String?
  assignee           User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById        String
  createdBy          User      @relation("TaskCreator", fields: [createdById], references: [id])
  branchId           String?
  branch             Branch?   @relation(fields: [branchId], references: [id])
  sourceEmailText    String?
  sourceSender       String?
  generatedReplyText String?
  replySent          Boolean   @default(false)
  dueDate            DateTime?
  // Renewal tracking
  isRenewal          Boolean   @default(false)
  renewalExpiryDate  DateTime?
  renewalProvider    String?
  // Follow-up tracking
  followUpFrequencyHours Int?
  lastFollowUpAt     DateTime?
  followUpCount      Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  closedAt           DateTime?

  activityLogs  ActivityLog[]
  comments      Comment[]
  notifications Notification[]
  followUps     FollowUp[]
}

// actionType: "created" | "status_change" | "assigned" | "unassigned" | "priority_change"
//            | "due_date_change" | "comment" | "reply_generated" | "reply_sent"
//            | "category_change" | "title_change" | "description_change" | "closed"
//            | "follow_up" | "renewal_alert" | "escalation"
model ActivityLog {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  actionType String
  content    String
  createdAt  DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

// type: "assigned" | "due_soon" | "overdue" | "comment" | "done_needs_verification"
//     | "reply_not_sent" | "in_review_reminder" | "status_change"
//     | "renewal_30d" | "renewal_14d" | "renewal_7d" | "renewal_1d" | "renewal_expired"
//     | "follow_up" | "escalation"
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// FollowUp: each follow-up reminder/escalation generated by the system for a task
// type: "reminder" | "escalation" | "overdue" | "renewal"
model FollowUp {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  message     String
  sentToUserId String?
  sentTo      User?    @relation(fields: [sentToUserId], references: [id])
  createdAt   DateTime @default(now())
}

// Singleton settings row (id = "singleton")
model Setting {
  id                    String   @id @default("singleton")
  companyName           String   @default("WorkFlow Hub")
  defaultTone           String   @default("formal")
  urgentHours           Int      @default(4)
  highDays              Int      @default(1)
  mediumDays            Int      @default(3)
  lowDays               Int      @default(7)
  reminderHoursBefore   Int      @default(24)
  overdueCheckHours     Int      @default(2)
  inReviewReminderHours Int      @default(24)
  replyNotSentHours     Int      @default(4)
  // Renewal alert thresholds (days before expiry)
  renewalAlertDays      String   @default("30,14,7,1")
  // Follow-up defaults
  defaultFollowUpHours  Int      @default(48)
  escalationOverdueHours Int     @default(72)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
